# =============================================================
# AI GTM ENGINEER - ENVIRONMENT CONFIGURATION
# Stack: OpenAI + Serper + Resend + Gmail + Apollo + HubSpot + Supabase
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values below
#   3. NEVER commit .env to GitHub (it is in .gitignore)
# =============================================================


# -------------------------------------------------------------
# APP
# -------------------------------------------------------------
APP_NAME=ai-gtm-engineer
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
SECRET_KEY=your-secret-key-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=7d


# -------------------------------------------------------------
# DATABASE - Supabase (PostgreSQL)
# Get from: https://supabase.com -> Project -> Settings -> Database
# -------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key


# -------------------------------------------------------------
# LLM - OpenAI
# Get from: https://platform.openai.com/api-keys
# -------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small


# -------------------------------------------------------------
# WEB SEARCH - Serper
# Get from: https://serper.dev -> Dashboard -> API Key
# -------------------------------------------------------------
SERPER_API_KEY=your-serper-api-key


# -------------------------------------------------------------
# EMAIL - Resend (primary)
# Get from: https://resend.com -> API Keys
# -------------------------------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
FROM_EMAIL=you@yourdomain.com
FROM_NAME=Your Name

# EMAIL - Gmail SMTP (backup / alternative)
# App Password: https://myaccount.google.com -> Security -> App Passwords
# Set EMAIL_PROVIDER=smtp to use Gmail instead of Resend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password


# -------------------------------------------------------------
# ENRICHMENT - Apollo.io
# Get from: https://app.apollo.io -> Settings -> Integrations -> API
# -------------------------------------------------------------
APOLLO_API_KEY=your-apollo-api-key


# -------------------------------------------------------------
# CRM - HubSpot
# Get from: https://app.hubspot.com -> Settings -> Integrations -> Private Apps
# Create a Private App with: crm.objects.contacts, crm.objects.deals, crm.objects.notes
# -------------------------------------------------------------
CRM_PROVIDER=hubspot
HUBSPOT_API_KEY=pat-...


# -------------------------------------------------------------
# CALENDAR (optional - add later)
# -------------------------------------------------------------
# CALENDAR_PROVIDER=google
# GOOGLE_CALENDAR_CREDENTIALS=path/to/service-account.json
# GOOGLE_CALENDAR_ID=primary
# CALENDLY_API_KEY=your-calendly-key


# -------------------------------------------------------------
# VECTOR MEMORY - ChromaDB (local, no key needed)
# -------------------------------------------------------------
VECTOR_BACKEND=chroma
CHROMA_PATH=./data/chroma
MEMORY_BACKEND=local


# -------------------------------------------------------------
# BROWSER AUTOMATION - Playwright (no key needed)
# -------------------------------------------------------------
PLAYWRIGHT_HEADLESS=true
BROWSER_TIMEOUT=30000


# -------------------------------------------------------------
# LOGGING
# -------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
