# ============================================================
# AI GTM ENGINEER - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# --- APP ---
APP_NAME=ai-gtm-engineer
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=7d

# --- DATABASE (Supabase / PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:5432/ai_gtm_engineer
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# --- NVIDIA NIM API ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=nvidia/nemotron-3-8b-chat-4k

# --- OPENAI (fallback/embedding) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- VECTOR DATABASE ---
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=ai-gtm-engineer

# --- EMAIL PROVIDER (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=AI GTM Engineer

# --- CRM (HubSpot) ---
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_PORTAL_ID=your-portal-id

# --- GOOGLE CALENDAR ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- LEAD ENRICHMENT (Apollo) ---
APOLLO_API_KEY=your-apollo-api-key

# --- WEB SEARCH (Serper/Tavily) ---
SERPER_API_KEY=your-serper-api-key
TAVILY_API_KEY=your-tavily-api-key

# --- WORKFLOW ENGINE (n8n) ---
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# --- SLACK NOTIFICATIONS ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx

# --- BROWSER AUTOMATION ---
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# --- LOGGING ---
LOG_LEVEL=info
LOG_FILE=logs/app.log
